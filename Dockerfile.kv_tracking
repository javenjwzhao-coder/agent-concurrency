# Dockerfile.kv_tracking
#
# Builds a patched vLLM Ascend image with per-agent KV-block tracking.
# Targets Ascend 910C (Atlas A3); base image built from Dockerfile.vllm_ascend_a3.
#
# Base image installs vLLM as an editable pip install at:
#   /vllm-workspace/vllm/   (source tree)
# so replacing .py files there takes effect immediately — no wheel rebuild.
#
# Usage (from repo root):
#   docker build -f Dockerfile.kv_tracking \
#                -t agent-concurrency/vllm-kv-tracking:v0.13m \
#                src/
#
# The build context must be src/ so that vllm_patches/ is available.

FROM quay.io/ascend/vllm-ascend:v0.13m-a3

# ── Copy patch script ──────────────────────────────────────────────────────────
COPY vllm_patches/apply_patches.py /tmp/apply_patches.py

# ── Apply patches ──────────────────────────────────────────────────────────────
# The script modifies the editable-install source in place and validates the
# result.  Any pattern-mismatch exits non-zero, failing the build early.
RUN python3 /tmp/apply_patches.py

# ── Purge stale bytecode ───────────────────────────────────────────────────────
# Python caches .pyc files in __pycache__/; purge them so the runtime picks
# up the freshly written .py files rather than the old compiled bytecode.
RUN find /vllm-workspace/vllm/vllm/entrypoints/openai/__pycache__ \
         -name "protocol*.pyc" \
         -o -name "serving_chat*.pyc" \
         2>/dev/null | xargs rm -f ; true

# ── Smoke-test: import the patched modules ────────────────────────────────────
RUN python3 - <<'EOF'
import vllm.entrypoints.openai.protocol as p
import vllm.entrypoints.openai.serving_chat  # noqa: just import-check

assert "kv_blocks_used"    in p.UsageInfo.model_fields, "kv_blocks_used missing"
assert "kv_blocks_size_gb" in p.UsageInfo.model_fields, "kv_blocks_size_gb missing"
assert "agent_id"          in p.ChatCompletionRequest.model_fields, "agent_id missing"
print("Dockerfile smoke-test passed: patched fields present.")
EOF

# ── Everything else is inherited from the base image ─────────────────────────
# NPU device nodes, CANN libraries, vllm_ascend plugin, ENTRYPOINT, CMD — all
# unchanged.  The container is started with `vllm serve` as usual via
# start_vllm.sh.
