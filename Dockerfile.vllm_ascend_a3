# Dockerfile.vllm_ascend_a3
#
# Builds quay.io/ascend/vllm-ascend:v0.13m-a3 for Ascend 910C (Atlas A3 / SOC ascend910_9391).
# Based on the upstream vllm-ascend v0.13.0 Dockerfile.a3, modified to replace the
# `COPY . /vllm-workspace/vllm-ascend/` with a `git clone` so the build is fully
# self-contained (no local source checkout required as build context).
#
# Usage (from repo root):
#   docker build \
#       -f Dockerfile.vllm_ascend_a3 \
#       -t quay.io/ascend/vllm-ascend:v0.13m-a3 \
#       .

FROM quay.io/ascend/cann:8.5.1-a3-ubuntu22.04-py3.11

ARG PIP_INDEX_URL="https://mirrors.tuna.tsinghua.edu.cn/pypi/web/simple"
ARG MOONCAKE_TAG="v0.3.7.post2"
ARG SOC_VERSION="ascend910_9391"
ARG VLLM_ASCEND_TAG="v0.13.0"
ARG VLLM_REPO="https://github.com/vllm-project/vllm.git"
ARG VLLM_TAG="v0.13.0"

ENV DEBIAN_FRONTEND=noninteractive
ENV SOC_VERSION=$SOC_VERSION \
    TASK_QUEUE_ENABLE=1 \
    OMP_NUM_THREADS=1

WORKDIR /workspace

RUN pip config set global.index-url ${PIP_INDEX_URL}

# Install system packages, clone vllm-ascend source, and build Mooncake in one layer
RUN apt-get update -y && \
    apt-get install -y git vim wget net-tools gcc g++ cmake libnuma-dev libjemalloc2 && \
    rm -rf /var/cache/apt/* /var/lib/apt/lists/* && \
    git clone --depth 1 --branch ${VLLM_ASCEND_TAG} \
        https://github.com/vllm-project/vllm-ascend \
        /vllm-workspace/vllm-ascend/ && \
    git clone --depth 1 --branch ${MOONCAKE_TAG} \
        https://github.com/kvcache-ai/Mooncake \
        /vllm-workspace/Mooncake && \
    cp /vllm-workspace/vllm-ascend/tools/mooncake_installer.sh \
       /vllm-workspace/Mooncake/ && \
    cd /vllm-workspace/Mooncake && bash mooncake_installer.sh -y && \
    export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:/usr/local/Ascend/ascend-toolkit/latest/`uname -i`-linux/lib64 && \
    mkdir -p build && cd build && cmake .. -DUSE_ASCEND_DIRECT=ON && \
    make -j$(nproc) && make install && \
    rm -fr /vllm-workspace/Mooncake/build

# Clone and install vLLM (empty device build, strip triton — incompatible with Ascend)
RUN git clone --depth 1 $VLLM_REPO --branch $VLLM_TAG /vllm-workspace/vllm && \
    VLLM_TARGET_DEVICE="empty" python3 -m pip install -v \
        -e /vllm-workspace/vllm/[audio] \
        --extra-index https://download.pytorch.org/whl/cpu/ && \
    python3 -m pip uninstall -y triton && \
    python3 -m pip cache purge

# Install vllm-ascend plugin
RUN export PIP_EXTRA_INDEX_URL=https://mirrors.huaweicloud.com/ascend/repos/pypi && \
    source /usr/local/Ascend/ascend-toolkit/set_env.sh && \
    source /usr/local/Ascend/nnal/atb/set_env.sh && \
    export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:/usr/local/Ascend/ascend-toolkit/latest/`uname -i`-linux/devlib && \
    python3 -m pip install -v \
        -e /vllm-workspace/vllm-ascend/ \
        --extra-index https://download.pytorch.org/whl/cpu/ && \
    python3 -m pip cache purge

# Install clang-15 (required for triton-ascend compilation)
RUN apt-get update -y && \
    apt-get -y install clang-15 && \
    update-alternatives --install /usr/bin/clang clang /usr/bin/clang-15 20 && \
    update-alternatives --install /usr/bin/clang++ clang++ /usr/bin/clang++-15 20 && \
    rm -rf /var/cache/apt/* /var/lib/apt/lists/*

# Install Python runtime dependencies
RUN python3 -m pip install modelscope 'ray>=2.47.1,<=2.48.0' 'protobuf>3.20.0' && \
    python3 -m pip cache purge

RUN echo "export LD_PRELOAD=/usr/lib/$(uname -m)-linux-gnu/libjemalloc.so.2:$LD_PRELOAD" \
        >> ~/.bashrc

CMD ["/bin/bash"]
